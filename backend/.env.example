# Environment variables for the Watson Control Tower backend
# Copy this file to .env and fill in the values

# Port to listen on (Render.com sets this automatically)
PORT=3001

# PostgreSQL connection string (Supabase, Render Postgres, or any PostgreSQL provider).
# When set, all activity logs, alerts, and custom filters are stored in the
# database and survive server restarts. Without this the server runs fully
# in-memory (data lost on restart).
#
# Supabase PostgreSQL (Transaction Pooler — recommended for serverless/backend):
#   postgresql://postgres.qwxixzdsfrckcqeuried:<DB_PASSWORD>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
# Supabase PostgreSQL (Direct connection):
#   postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
#
# Replace <DB_PASSWORD> with your Supabase database password.
DATABASE_URL=
