# Environment variables for the PalsPlan Parental Monitor backend
# Copy this file to .env and fill in the values

# Port to listen on (Render.com sets this automatically)
PORT=3001

# PostgreSQL connection string (Render Postgres or any PostgreSQL provider).
# When set, all activity logs, alerts, and custom filters are stored in the
# database and survive server restarts. Without this the server runs fully
# in-memory (data lost on restart).
# Example: postgresql://user:password@hostname/dbname
DATABASE_URL=
