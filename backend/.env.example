# Environment variables for the PalsPlan Parental Monitor backend
# Copy this file to .env and fill in the values

# Port to listen on (Render.com sets this automatically)
PORT=3001

# CORS origin for the parent dashboard (set to your Vercel dashboard URL)
# Examples:
#   DASHBOARD_ORIGIN=https://dashboard.palsplan.app
#   DASHBOARD_ORIGIN=https://my-dashboard.vercel.app
# Set to * to allow any origin (development only — not recommended for production)
DASHBOARD_ORIGIN=*
