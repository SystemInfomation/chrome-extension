<!--
  Chrome extension update manifest for Watson Control Tower.

  The Watson Control Tower backend now serves this manifest dynamically at:
    GET https://<YOUR_BACKEND_URL>/updates.xml

  The .crx file is served at:
    GET https://<YOUR_BACKEND_URL>/extension.crx

  Set the BACKEND_URL and (optionally) EXTENSION_ID environment variables
  on the backend deployment.  Place the built extension.crx file at
  backend/public/extension.crx before deploying.

  This static copy is kept here as a fallback / reference only.
  Prefer the backend-served version in production.

  Extension ID: lmaaddldfngeapalhdhgbeeipbjalioe

  Reference: https://developer.chrome.com/docs/extensions/how-to/distribute/host-on-linux
-->
<gupdate xmlns='http://www.google.com/update2/response' protocol='2.0'>
  <app appid='lmaaddldfngeapalhdhgbeeipbjalioe'>
    <updatecheck codebase='https://<YOUR_BACKEND_URL>/extension.crx' version='1' />
  </app>
</gupdate>
