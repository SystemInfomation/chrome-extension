{
  "manifest_version": 3,
  "name": "PalsPlan Web Protector",
  "version": "3.7.5",
  "description": "Protects users from adult content, malicious websites, phishing, and suspicious URLs using offline heuristics and a bundled domain blocklist. No data is collected or transmitted.",
  "incognito": "spanning",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PalsPlan Web Protector",
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "dist/background.bundle.js"
  },

  "permissions": [
    "webNavigation",
    "tabs",
    "storage",
    "alarms",
    "notifications",
    "declarativeNetRequest"
  ],

  "host_permissions": [
    "*://*/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
  }
}
