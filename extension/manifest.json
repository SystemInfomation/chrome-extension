{
  "manifest_version": 3,
  "name": "PalsPlan Web Protector",
  "version": "2.0.2",
  "description": "Web protection extension that blocks adult content and malicious/suspicious websites.",
  "incognito": "spanning",

  "background": {
    "service_worker": "dist/background.bundle.js"
  },

  "permissions": [
    "webNavigation",
    "tabs",
    "storage",
    "alarms",
    "notifications",
    "declarativeNetRequest",
    "management"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
  }
}
