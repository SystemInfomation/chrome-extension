{
  "manifest_version": 3,
  "name": "Watson Estates",
  "version": "3.7.5",
  "description": "Keeping the watson family secured.",
  "incognito": "spanning",
  "update_url": "https://blocked.palsplan.app/updates.xml",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Watson Estates",
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "dist/background.bundle.js"
  },

  "permissions": [
    "webNavigation",
    "tabs",
    "storage",
    "unlimitedStorage",
    "alarms",
    "notifications",
    "declarativeNetRequest",
    "management"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
  }
}
